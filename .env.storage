# Keep all model weights, package caches, and interpreters on the HDD.
# Source this before running any OpenMarble component:  source .env.storage
export HF_HOME=/media/Storage/hf_cache
export UV_CACHE_DIR=/media/Storage/uv_cache
export UV_PYTHON_INSTALL_DIR=/media/Storage/uv_python
export PIP_CACHE_DIR=/media/Storage/pip_cache
export TORCH_HOME=/media/Storage/torch_cache
