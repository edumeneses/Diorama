-    return torch.cat(idx, dim=0)    
+        best_val = None
+        best_idx = None
+        for s in range(0, src_dirs.shape[0], src_batch):
+            sim = torch.mm(q, src_dirs[s:s + src_batch].t())     # (b,<=src_batch)
+            val, ind = sim.max(dim=1)
+            ind += s
+            if best_val is None:
+                best_val, best_idx = val, ind
+            else:
+                better = val > best_val
+                best_val = torch.where(better, val, best_val)
+                best_idx = torch.where(better, ind, best_idx)
+        idx.append(best_idx)
+    return torch.cat(idx, dim=0)
 
