+def batch_nearest_dot(src_dirs, query_dirs, batch=4096, src_batch=131072):
     """
     For each query vector find the index of the source vector with the
     largest dot product.  Works on CUDA or CPU.
+
+    Chunks over both query and source dims with a running max so the
+    similarity matrix never exceeds batch*src_batch elements (~2 GiB
+    fp32 with the defaults), instead of materialising (b, N) at once.
     """
     src_dirs = F.normalize(src_dirs, dim=1)
     query_dirs = F.normalize(query_dirs, dim=1)
     idx = []
     for start in range(0, query_dirs.shape[0], batch):
         q = query_dirs[start:start + batch]                      # (b,3)
-        sim = torch.mm(q, src_dirs.t())                          # (b,N)
-        idx.append(sim.argmax(dim=1))
-    return torch.cat(idx, dim=0)    
+        best_val = None
+        best_idx = None
+        for s in range(0, src_dirs.shape[0], src_batch):
+            sim = torch.mm(q, src_dirs[s:s + src_batch].t())     # (b,<=src_batch)
+            val, ind = sim.max(dim=1)
+            ind += s
+            if best_val is None:
+                best_val, best_idx = val, ind
+            else:
+                better = val > best_val
+                best_val = torch.where(better, val, best_val)
+                best_idx = torch.where(better, ind, best_idx)
+        idx.append(best_idx)
+    return torch.cat(idx, dim=0)
 
