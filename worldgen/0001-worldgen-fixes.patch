+import math
+
 import torch
 import numpy as np
 from PIL import Image
 from da2.model.spherevit import SphereViT
 from .utils.general_utils import pano_unit_rays
 
+# Assumed horizontal FOV for perspective inputs. UniK3D used to estimate the
+# camera; DA-2 doesn't, so we assume a typical photo FOV. Affects how large
+# the input appears in the panorama, not correctness of the fill.
+PERSPECTIVE_HFOV_DEG = 65.0
+
+
+def perspective_unit_rays(h: int, w: int, device, hfov_deg: float = PERSPECTIVE_HFOV_DEG):
+    """Pinhole camera rays (+z forward, x right, y down) matching the
+    equirectangular convention used by map_image_to_pano (phi = atan2(x, z),
+    theta = asin(y))."""
+    fx = (w / 2.0) / math.tan(math.radians(hfov_deg) / 2.0)
+    v, u = torch.meshgrid(
+        torch.arange(h, device=device, dtype=torch.float32),
+        torch.arange(w, device=device, dtype=torch.float32),
+        indexing="ij",
+    )
+    x = (u - (w - 1) / 2.0) / fx
+    y = (v - (h - 1) / 2.0) / fx
+    z = torch.ones_like(x)
+    rays = torch.stack((x, y, z), dim=-1)
+    return torch.nn.functional.normalize(rays, dim=-1)
+
 MAX_DISTANCE = 20.0  # Scale DA-2's scale-invariant output so max distance = 20 meters
 
+
+def _normalize_distance(distance: torch.Tensor) -> torch.Tensor:
+    """Map DA-2's scale-invariant output to (0, MAX_DISTANCE].
+
+    Normalizing by the raw max is fragile: a handful of outlier predictions
+    (common on diffusion-generated panoramas) compresses the whole scene into
+    a tiny ball around the origin. Use the 99th percentile as the reference
+    scale and clamp the outlier tail instead.
+    """
+    ref = torch.quantile(distance.flatten(), 0.99)
+    if not torch.isfinite(ref) or ref <= 0:
+        ref = distance.max().clamp(min=1e-6)
+    distance = distance / ref * MAX_DISTANCE
+    return distance.clamp(max=MAX_DISTANCE * 1.25)
+
 # Default config matching DA-2's inference settings
 DA2_CONFIG = {
     "inference": {
